<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to Aura Weaver"
        android:textColor="#03DAC5"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aura Weaver translates your emotional state into generative art.

1. Select a vibe from the grid
2. Watch living art generate on the canvas
3. Customize your experience in Preferences
4. Your vibe history is saved automatically

This is an emotional mirror, not a game. No scores, no competition, only reflection."
        android:textColor="#FFFFFF"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Begin Weaving"
        android:backgroundTint="#6200EE"/>
</LinearLayout>
